        <GenericOperationConfig
          customOperationType="GET"
          objectTypeId="HR_Departments"
          operationType="EXECUTE"
          requestProfile="c1d25091-d71c-477f-846b-ca5051775959"
          requestProfileType="json"
          responseProfile="5b506932-188f-47f9-b65e-6a90ab79848d"
          responseProfileType="json">
          <field id="GetType" type="string" value="Standard Get"/>
          <field id="INClause" type="boolean" value="false"/>
          <field id="query" type="string" value="SELECT department_name, cost_center, manager_id, building_location, job_family FROM HR_Departments WHERE department_code = $department_code"/>
